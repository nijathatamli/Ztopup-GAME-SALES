# ============================================================
# PRODUCTION .env for ztopup.az (cPanel)
# Copy this to ".env" ON THE SERVER (in the app root folder).
# IMPORTANT: On the cPanel server the database is LOCAL, so
# DB_HOST must be "localhost" (NOT ztopup.az). PostgreSQL on
# shared hosting only accepts connections from the server itself.
# ============================================================

# --- Database (server-local PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=dqkxfqmx_zelix
DB_PASSWORD=CHANGE_ME_real_db_password
DB_NAME=dqkxfqmx_ztopup_user_database

# Local connections usually do NOT use SSL on cPanel:
PGSSLMODE=disable
PGCONNECT_TIMEOUT=5

# --- Node app ---
# cPanel/Passenger sets PORT automatically; leave as-is for local runs.
PORT=8091

# --- Security: set a long random secret (used to sign login tokens) ---
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_long_random_string
