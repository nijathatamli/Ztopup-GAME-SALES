# Server Configuration
PORT=3000
NODE_ENV=development

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zelix_auth
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=true

# JWT Configuration
# IMPORTANT: Set a strong random string. The server will refuse to start without it.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:8091

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
